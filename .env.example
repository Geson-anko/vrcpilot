# Optional environment for `just manual` on Linux.
#
# Copy this file to `.env` (gitignored) and adjust if your desktop
# session lives on a non-default display, or your X authority file is
# in a non-standard location. Existing shell environment variables
# take precedence over `.env`, and `.env` is itself optional --
# `just manual` falls back to the same defaults via the recipe when
# neither source provides a value.

# X11 display targeted by `just manual`. SSH sessions inherit no
# DISPLAY by default, so this is what surfaces VRChat on the local
# desktop. Override only if your desktop runs on a different display.
export DISPLAY=:0

# X authority cookie file for the above display. Override if your
# session stores it in a non-default location.
export XAUTHORITY=$HOME/.Xauthority
